# Copie para backend/.env (git-ignored) e ajuste. NENHUM segredo real vai para o repositório.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-secret-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_PORT=8000

# --- Banco (Postgres via backend/docker-compose.yml) ---
DATABASE_URL=postgres://aop:aop@localhost:5432/aop_platform

# --- Fronteira Node <-> Django (ADR-016) ---
# Mesmo valor precisa estar no game server (packages/server) — ver T-027g.
SERVICE_TOKEN=dev-service-token-change-me

# --- JWT RS256 (T-027c) ---
# Gerar o par (NÃO commitar): ver backend/README.md > "Chaves JWT".
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ISSUER=aop-platform
JWT_TTL_SECONDS=86400

# --- CORS (client Vite; usado a partir da T-028) ---
# 5173 = `npm run dev -w @aop/client` padrão; 5299 = client-verify (.claude/launch.json, CD)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5299
